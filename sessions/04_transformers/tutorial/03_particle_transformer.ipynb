    "# Test with random data\n",
    "np.random.seed(42)\n",
    "n, d = 10, 16\n",
    "Q_test = np.random.randn(n, d) * 0.1\n",
    "K_test = np.random.randn(n, d) * 0.1\n",
    "U_test = np.random.randn(n, n) * 0.5  # simulated interaction bias\n",
    "\n",
    "# Without bias\n",
    "attn_standard = particle_transformer_attention(Q_test, K_test, np.zeros((n, n)))\n",
    "# With bias\n",
    "attn_part = particle_transformer_attention(Q_test, K_test, U_test)\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 4))\n",
    "\n",
    "im0 = axes[0].imshow(attn_standard, cmap='Blues', vmin=0)\n",
    "axes[0].set_title('Standard attention\\n(no physics bias)')\n",
    "plt.colorbar(im0, ax=axes[0], shrink=0.8)\n",
    "\n",
    "im1 = axes[1].imshow(U_test, cmap='RdBu_r', vmin=-1.5, vmax=1.5)\n",
    "axes[1].set_title('Interaction bias U\\n(from physics features)')\n",
    "plt.colorbar(im1, ax=axes[1], shrink=0.8)\n",
    "\n",
    "im2 = axes[2].imshow(attn_part, cmap='Blues', vmin=0)\n",
    "axes[2].set_title('ParT attention\\n(standard + physics bias)')\n",
    "plt.colorbar(im2, ax=axes[2], shrink=0.8)\n",
    "\n",
    "for ax in axes:\n",
    "    ax.set_xlabel('Particle j')\n",
    "    ax.set_ylabel('Particle i')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"The physics bias reshapes the attention pattern. Standard attention is\")\n",
    "print(\"nearly uniform here (random Q, K); adding the bias introduces structure.\")"

    "# Identify the main components and their parameter counts\n",
    "def analyze_architecture(state_dict, name):\n",
    "    \"\"\"Group parameters by component and display a summary.\"\"\"\n",
    "    components = {}\n",
    "    \n",
    "    # Count blocks and cls_blocks\n",
    "    n_blocks = len(set(k.split('.')[1] for k in state_dict \n",
    "                       if k.startswith('mod.blocks.')))\n",
    "    n_cls = len(set(k.split('.')[2] for k in state_dict \n",
    "                     if k.startswith('mod.cls_blocks.')))\n",
    "    \n",
    "    for key, tensor in state_dict.items():\n",
    "        parts = key.replace('mod.', '').split('.')\n",
    "        if parts[0] == 'blocks':\n",
    "            comp = f'Transformer blocks (x{n_blocks})'\n",
    "        elif parts[0] == 'cls_blocks':\n",
    "            comp = f'CLS blocks (x{n_cls})'\n",
    "        elif parts[0] == 'embed':\n",
    "            comp = 'Particle embedding'\n",
    "        elif parts[0] == 'pair_embed':\n",
    "            comp = 'Pair embedding (physics)'\n",
    "        elif parts[0] == 'cls_token':\n",
    "            comp = 'Class token'\n",
    "        elif parts[0] == 'fc':\n",
    "            comp = 'Classification head'\n",
    "        elif parts[0] == 'norm':\n",
    "            comp = 'Final layer norm'\n",
    "        else:\n",
    "            comp = parts[0]\n",
    "        \n",
    "        components[comp] = components.get(comp, 0) + tensor.numel()\n",
    "    \n",
    "    total = sum(components.values())\n",
    "    print(f\"\\n{'=' * 60}\")\n",
    "    print(f\"  {name}\")\n",
    "    print(f\"{'=' * 60}\")\n",
    "    for comp, n in components.items():\n",
    "        pct = 100 * n / total\n",
    "        print(f\"  {comp:40s}  {n:>8,} ({pct:4.1f}%)\")\n",
    "    print(f\"  {'':40s}  {'':>8s}\")\n",
    "    print(f\"  {'TOTAL':40s}  {total:>8,}\")\n",
    "\n",
    "analyze_architecture(kin_weights, 'ParT_kin (7 kinematic features)')\n",
    "analyze_architecture(full_weights, 'ParT_full (17 features = kinematics + particle ID)')"
   ]
